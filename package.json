{
  "name": "devmarket",
  "version": "1.0.0",
  "description": "DevMarket Platform - Mobile App Marketplace",
  "main": "server/index.js",
  "scripts": {
    "setup": "node setup.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "test": "jest --setupFiles dotenv/config --runInBand",
    "test:client": "cd client && npm test",
    "android:dev": "cd client && cp capacitor.config.dev.json capacitor.config.json && npm run build && npx cap sync android",
    "android:prod": "cd client && git checkout capacitor.config.json && npm run build && npx cap copy android",
    "android:open": "cd client && npx cap open android",
    "clean": "rm -rf node_modules client/node_modules client/dist uploads/*.apk *.sqlite",
    "reset": "npm run clean && npm run setup"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "firebase-admin": "^12.0.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.9.2"
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "nodemon": "^2.0.22",
    "jest": "^29.7.0",
    "fast-check": "^3.19.0",
    "supertest": "^7.0.0",
    "memfs": "^4.9.2"
  }
}
