{
  "appId": "com.devmarket.app",
  "appName": "DevMarket",
  "webDir": "dist",
  "server": {
    "url": "http://192.168.0.103:3000",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "App": {
      "launchShowDuration": 0
    },
    "Browser": {
      "windowName": "_blank"
    },
    "GoogleSignIn": {
      "scopes": ["profile", "email"],
      "serverClientId": "484259839788-your-server-client-id.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  }
}