# Server
PORT=3000
LAN_IP=192.168.1.100
JWT_SECRET=your_random_secret_here
DEMO_ADMIN_EMAIL=admin.demo@gmail.com

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Database (set DB_TYPE to 'sqlite' for zero-setup fallback)
DB_TYPE=mysql
DB_HOST=localhost
DB_USER=devmarket_user
DB_PASSWORD=your_password_here
DB_NAME=devmarket
DB_PATH=./devmarket.sqlite

# CORS (leave blank to allow all origins on LAN)
CORS_ORIGIN=

# Client (set to your laptop's LAN IP)
VITE_API_BASE_URL=http://192.168.0.103:3000/api
